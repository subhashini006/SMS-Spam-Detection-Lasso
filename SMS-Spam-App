import streamlit as st
import pandas as pd
import numpy as np
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.linear_model import Lasso

# Load dataset
df = pd.read_csv('spam.csv', encoding='latin-1')

# Preprocess
df = df[['v1', 'v2']]
df.columns = ['label', 'message']
df['label'] = df['label'].map({'ham': 0, 'spam': 1})

# TF-IDF
vectorizer = TfidfVectorizer(stop_words='english')
X = vectorizer.fit_transform(df['message'])
y = df['label']

# Total features
total_features = X.shape[1]

# Train model
model = Lasso(alpha=0.1)
model.fit(X, y)

# Feature selection
coef = model.coef_
selected_features = np.sum(coef != 0)
eliminated_features = np.sum(coef == 0)
reduction = ((total_features - selected_features) / total_features) * 100

# UI
st.title("📩 SMS Spam Detection (Lasso)")

st.write(f"Total Features: {total_features}")
st.write(f"Selected Features: {selected_features}")
st.write(f"Eliminated Features: {eliminated_features}")
st.write(f"Feature Reduction: {reduction:.2f}%")

message = st.text_area("Enter SMS")

if st.button("Predict"):
    if message:
        X_input = vectorizer.transform([message])
        prediction = model.predict(X_input)

        if prediction[0] > 0.5:
            st.error("🚫 Spam Message")
        else:
            st.success("✅ Ham Message")
    else:
        st.warning("Please enter a message")
